# Rails runtime
RAILS_ENV=development
PORT=3000
RAILS_MAX_THREADS=5
RAILS_LOG_LEVEL=info

# GitHub OAuth (required for sign in)
GITHUB_CLIENT_ID=replace-with-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-app-client-secret

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=markdown_comments_development
DB_TEST_NAME=markdown_comments_test

# Redis / Sidekiq
REDIS_URL=redis://localhost:6379/0

# Production-only runtime secret
SECRET_KEY_BASE=replace-with-rails-secret-key-base
