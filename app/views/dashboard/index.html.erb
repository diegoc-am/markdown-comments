<% content_for :title, "Markdown Comments" %>

<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-amber-50">
  <header class="border-b border-slate-200 bg-white/90 backdrop-blur">
    <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
      <a href="/" class="text-lg font-semibold tracking-tight text-slate-900">Markdown Comments</a>
      <div class="flex items-center gap-3 text-sm">
        <% if user_signed_in? %>
          <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-700">@<%= current_user.github_login %></span>
          <%= button_to "Sign out", "/logout", method: :delete, class: "rounded-lg border border-slate-300 px-3 py-1.5 font-medium text-slate-700 hover:bg-slate-100", form_class: "inline" %>
        <% elsif github_oauth_configured? %>
          <a class="rounded-lg bg-slate-900 px-3 py-1.5 font-medium text-white hover:bg-slate-700" href="/login">Sign in with GitHub</a>
        <% else %>
          <span class="rounded-lg border border-slate-300 bg-slate-100 px-3 py-1.5 text-slate-500" aria-disabled="true">GitHub sign in unavailable</span>
        <% end %>
      </div>
    </div>
  </header>

  <main class="mx-auto w-full max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <% if notice.present? %>
      <div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-700"><%= notice %></div>
    <% end %>

    <% if alert.present? %>
      <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-700"><%= alert %></div>
    <% end %>

    <% unless github_oauth_configured? %>
      <div class="mb-4 rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-amber-900">
        <strong>GitHub OAuth is not configured.</strong>
        Add
        <% github_oauth_missing_vars.each_with_index do |env_var, index| %>
          <code class="rounded bg-amber-100 px-1 py-0.5"><%= env_var %></code><%= "," unless index == github_oauth_missing_vars.length - 1 %>
        <% end %>
        to your environment before trying to sign in.
      </div>
    <% end %>

    <section class="mb-6 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <h1 class="text-2xl font-semibold text-slate-900">Review markdown with inline comments</h1>
      <p class="mt-2 text-slate-600">GitHub PR-style workflow: comments render inline on top of the file, anchored by source lines.</p>
    </section>

    <% if user_signed_in? %>
      <section
        class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm"
        data-controller="comments-ui"
        data-comments-ui-index-url-value="/api/v1/comments"
        data-comments-ui-create-url-value="/api/v1/comments"
        data-comments-ui-update-url-template-value="/api/v1/comments/:id"
        data-comments-ui-delete-url-template-value="/api/v1/comments/:id"
        data-comments-ui-current-user-id-value="<%= current_user.id %>"
      >
        <div class="mb-4">
          <div>
            <label for="source_url" class="mb-1 block text-sm font-medium text-slate-700">GitHub File URL</label>
            <input id="source_url" name="source_url" type="url" required value="" placeholder="Select a repository file below or paste a GitHub file URL" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none" data-comments-ui-target="sourceUrlInput" data-action="change->comments-ui#loadComments">
          </div>
        </div>

        <div class="mb-4 rounded-lg border border-slate-200 bg-slate-50 p-3" data-comments-ui-target="repositoryGroups">
          <p class="text-sm text-slate-500">Loading visible repositories...</p>
        </div>

        <div class="mb-3 text-sm text-slate-700" data-comments-ui-target="documentMeta"></div>
        <div data-comments-ui-target="errorBox"></div>

        <div class="overflow-hidden rounded-lg border border-slate-200">
          <div class="flex items-center justify-between border-b border-slate-200 bg-slate-50 px-3 py-2 text-xs font-medium uppercase tracking-wide text-slate-500">
            <span>File Review</span>
            <div class="flex items-center gap-2 normal-case tracking-normal">
              <button type="button" class="rounded border border-slate-300 bg-white px-2 py-1 text-xs text-slate-700 hover:bg-slate-100" data-comments-ui-target="rawModeButton" data-action="click->comments-ui#showRawMode">Raw</button>
              <button type="button" class="rounded border border-slate-300 bg-white px-2 py-1 text-xs text-slate-700 hover:bg-slate-100" data-comments-ui-target="renderedModeButton" data-action="click->comments-ui#showRenderedMode">Rendered</button>
              <button type="button" class="rounded border border-slate-300 bg-white px-2 py-1 text-xs text-slate-700 hover:bg-slate-100" data-action="click->comments-ui#copyCurrentContextLink">Copy Link</button>
            </div>
          </div>
          <div class="max-h-[70vh] overflow-auto bg-white" data-comments-ui-target="documentPreview" data-action="mousedown->comments-ui#onDocumentMouseDown mouseover->comments-ui#onDocumentMouseOver mouseup->comments-ui#onDocumentMouseUp mouseleave->comments-ui#onDocumentMouseUp click->comments-ui#onDocumentClick input->comments-ui#onEditorInput"></div>
        </div>
      </section>
    <% else %>
      <section class="rounded-xl border border-slate-200 bg-white p-6 text-slate-700 shadow-sm">
        <% if github_oauth_configured? %>
          Sign in with GitHub to start saving and managing comments.
        <% else %>
          Configure GitHub OAuth first, then refresh this page to enable sign in.
        <% end %>
      </section>
    <% end %>
  </main>
</div>
