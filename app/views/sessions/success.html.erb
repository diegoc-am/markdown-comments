<% content_for :title, "Signed In" %>

<main class="flex min-h-screen items-center justify-center bg-slate-50 px-4">
  <section class="w-full max-w-lg rounded-xl border border-slate-200 bg-white p-8 text-center shadow-sm">
    <div class="mx-auto h-10 w-10 animate-spin rounded-full border-4 border-slate-200 border-t-slate-900" aria-hidden="true"></div>
    <h1 class="mt-4 text-2xl font-semibold text-slate-900">Welcome, @<%= @github_login %></h1>
    <p class="mt-2 text-slate-600">Authentication succeeded. Taking you to your comments workspace...</p>
    <p class="mt-3"><a href="/" class="text-sm font-medium text-slate-700 underline hover:text-slate-900">Continue now</a></p>
  </section>
</main>

<script>
  setTimeout(function() {
    window.location.assign("/")
  }, 1200)
</script>
